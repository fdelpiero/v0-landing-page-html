+export type Locale = "en" | "es"
+
+export const locales: Locale[] = ["en", "es"]
+
+export function localizedPath(locale: Locale, path: string) {
+  if (path.startsWith("#")) return path
+  if (locale === "es") return path === "/" ? "/es" : `/es${path}`
+  return path
+}
